# ── Wiki repo ──────────────────────────────────────────────────────────────────
WIKI_REPO_URL=https://github.com/your-username/wiki.git
WIKI_PATH=./wiki-data

# GitHub token with repo scope — obtained automatically via `npx create-llm-wiki`
GITHUB_TOKEN=

# ── Sync & reconciler ──────────────────────────────────────────────────────────
SYNC_INTERVAL_MS=60000
RECONCILE_CRON=0 7 * * *
TZ=America/Denver

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_SECRET=change-me

# Disable login for single-user / local deployments
SKIP_AUTH=true

# GitHub Device Flow auth (when SKIP_AUTH=false)
# Create a GitHub OAuth App with Device Flow enabled — no redirect URI needed.
# AUTH_GITHUB_ID=your-client-id
# AUTH_SECRET=change-me-to-a-random-string
# ALLOWED_GITHUB_USERNAME=your-github-username

# ── Claude Code credentials ────────────────────────────────────────────────────
# Only needed when running in a container / server environment without a
# local Claude Code install. Base64-encode your credentials file:
#   base64 < ~/.claude/.credentials.json
# CLAUDE_CREDS_JSON=
