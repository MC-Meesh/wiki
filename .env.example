# ── Wiki repo ──────────────────────────────────────────────────────────────────
WIKI_REPO_URL=https://github.com/your-username/wiki.git
WIKI_PATH=./wiki-data

# GitHub token with repo scope (for git push/pull)
# Obtained automatically via device flow during setup, or set manually.
GITHUB_TOKEN=

# ── LLM provider ───────────────────────────────────────────────────────────────
# Options: claude-cli | anthropic | openai | ollama
LLM_PROVIDER=claude-cli

# Model override (optional — each provider has a sensible default)
# LLM_MODEL=claude-sonnet-4-5

# API key — required for anthropic and openai providers
# LLM_API_KEY=

# Base URL — required for ollama (default: http://localhost:11434)
# LLM_BASE_URL=

# ── Sync & reconciler ──────────────────────────────────────────────────────────
# How often to pull/push the wiki repo (milliseconds)
SYNC_INTERVAL_MS=60000

# Cron schedule for daily todo reconciler (default: 7am)
RECONCILE_CRON=0 7 * * *

# Timezone for the reconciler and daily file naming
TZ=America/Denver

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# Secret for the /api/webhook endpoint (used by GitHub webhook for instant pull)
WEBHOOK_SECRET=change-me

# Set to true to disable login (recommended for local/private deployments)
SKIP_AUTH=true

# PIN for the login page when SKIP_AUTH=false (any numeric or string PIN)
# ACCESS_PIN=1234

# Random secret used to sign the session cookie — change this
SESSION_SECRET=change-me-to-a-random-string

# ── Optional: Claude Code credentials (base64-encoded JSON) ───────────────────
# Only needed when LLM_PROVIDER=claude-cli in a container environment.
# Obtain with: base64 < ~/.claude/.credentials.json
# CLAUDE_CREDS_JSON=
